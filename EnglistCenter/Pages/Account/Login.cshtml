@page
@model EnglistCenter.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="d-flex justify-content-center align-items-center login-fullscreen">
    <div class="card shadow-lg login-card">
        <div class="card-body p-4">
            <div class="text-center mb-4">
                <h3 class="mb-0">EnglistCenter</h3>
                <small class="text-muted">Sign in to manage classes and enrollments</small>
            </div>

            <form method="post" novalidate>
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="Input.UserName" class="form-label">User name</label>
                    <input asp-for="Input.UserName" class="form-control form-control-lg" />
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label">Password</label>
                    <input asp-for="Input.Password" type="password" class="form-control form-control-lg" />
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary btn-lg">Sign in</button>
                </div>

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger mt-3">@Model.ErrorMessage</div>
                }
            </form>

            <div class="text-center mt-3 text-muted small">
                Forgotten password? Contact administrator.
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
