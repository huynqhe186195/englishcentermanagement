@page
@model dynamic
@{
    ViewData["Title"] = "Admin Dashboard";
}

<section class="admin-hero mb-4">
    <div>
        <span class="badge rounded-pill text-bg-light mb-2">Campus Admin</span>
        <h1 class="h3 mb-2">Bảng điều khiển quản trị trung tâm</h1>
        <p class="mb-0">Theo dõi học viên, lớp học, doanh thu và các công việc cần xử lý trong ngày trên một màn hình duy nhất.</p>
    </div>
    <a class="btn btn-light fw-semibold" href="/Student">Xem giao diện Student</a>
</section>

<section class="row g-3 mb-4">
    <div class="col-12 col-md-6 col-xl-3">
        <article class="stat-card stat-card-primary h-100">
            <p class="stat-label">Học viên đang học</p>
            <h2 class="stat-value">1,284</h2>
            <p class="stat-trend text-success mb-0">+9.8% so với tháng trước</p>
        </article>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <article class="stat-card stat-card-info h-100">
            <p class="stat-label">Lớp đang hoạt động</p>
            <h2 class="stat-value">76</h2>
            <p class="stat-trend text-success mb-0">+6 lớp mới trong tuần</p>
        </article>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <article class="stat-card stat-card-warning h-100">
            <p class="stat-label">Học phí đến hạn</p>
            <h2 class="stat-value">54</h2>
            <p class="stat-trend text-warning mb-0">12 hồ sơ cần nhắc hôm nay</p>
        </article>
    </div>
    <div class="col-12 col-md-6 col-xl-3">
        <article class="stat-card stat-card-success h-100">
            <p class="stat-label">Doanh thu tháng</p>
            <h2 class="stat-value">1.62 tỷ</h2>
            <p class="stat-trend text-success mb-0">Đạt 83% kế hoạch</p>
        </article>
    </div>
</section>

<section class="row g-3 mb-4">
    <div class="col-12 col-xl-8">
        <article class="panel-card h-100">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                <div>
                    <h2 class="h5 mb-1">Tiến độ vận hành trong tuần</h2>
                    <p class="text-secondary mb-0">Tổng hợp điểm danh, thu phí và chất lượng lớp học.</p>
                </div>
                <button type="button" class="btn btn-outline-primary btn-sm">Xuất báo cáo</button>
            </div>

            <div class="progress-group">
                <div>
                    <div class="d-flex justify-content-between mb-1"><span>Tỷ lệ điểm danh</span><strong>94%</strong></div>
                    <div class="progress" role="progressbar" aria-label="Tỷ lệ điểm danh" aria-valuenow="94" aria-valuemin="0" aria-valuemax="100">
                        <div class="progress-bar bg-primary" style="width: 94%"></div>
                    </div>
                </div>
                <div>
                    <div class="d-flex justify-content-between mb-1"><span>Thu học phí đúng hạn</span><strong>88%</strong></div>
                    <div class="progress" role="progressbar" aria-label="Thu học phí đúng hạn" aria-valuenow="88" aria-valuemin="0" aria-valuemax="100">
                        <div class="progress-bar bg-success" style="width: 88%"></div>
                    </div>
                </div>
                <div>
                    <div class="d-flex justify-content-between mb-1"><span>Lớp học đạt chuẩn sĩ số</span><strong>91%</strong></div>
                    <div class="progress" role="progressbar" aria-label="Lớp học đạt chuẩn sĩ số" aria-valuenow="91" aria-valuemin="0" aria-valuemax="100">
                        <div class="progress-bar bg-info" style="width: 91%"></div>
                    </div>
                </div>
            </div>
        </article>
    </div>

    <div class="col-12 col-xl-4">
        <article class="panel-card h-100">
            <h2 class="h5 mb-3">Việc cần xử lý ngay</h2>
            <ul class="task-list">
                <li>
                    <span class="task-dot dot-warning"></span>
                    8 học viên chưa hoàn tất hồ sơ nhập học
                </li>
                <li>
                    <span class="task-dot dot-danger"></span>
                    3 lớp thiếu giáo viên tuần này
                </li>
                <li>
                    <span class="task-dot dot-info"></span>
                    5 phụ huynh yêu cầu tư vấn lộ trình mới
                </li>
                <li>
                    <span class="task-dot dot-success"></span>
                    14 hóa đơn đã thanh toán chờ xác nhận
                </li>
            </ul>
        </article>
    </div>
</section>

<section class="panel-card">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <h2 class="h5 mb-0">Danh sách lớp nổi bật</h2>
        <a class="btn btn-outline-secondary btn-sm" href="#">Xem toàn bộ lớp</a>
    </div>
    <div class="table-responsive">
        <table class="table align-middle admin-table mb-0">
            <thead>
                <tr>
                    <th>Lớp</th>
                    <th>Giáo viên</th>
                    <th>Sĩ số</th>
                    <th>Tỷ lệ điểm danh</th>
                    <th>Trạng thái</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>IELTS Foundation F3</td>
                    <td>Ms. Linh</td>
                    <td>22/24</td>
                    <td>96%</td>
                    <td><span class="badge text-bg-success">Ổn định</span></td>
                </tr>
                <tr>
                    <td>English Communication B1</td>
                    <td>Mr. James</td>
                    <td>19/20</td>
                    <td>89%</td>
                    <td><span class="badge text-bg-warning">Cần theo dõi</span></td>
                </tr>
                <tr>
                    <td>Kids Starter K2</td>
                    <td>Ms. Hương</td>
                    <td>17/18</td>
                    <td>93%</td>
                    <td><span class="badge text-bg-primary">Đang tăng trưởng</span></td>
                </tr>
            </tbody>
        </table>
    </div>
</section>
