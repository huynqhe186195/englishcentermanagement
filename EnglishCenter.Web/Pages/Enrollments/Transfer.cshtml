@page "{id:long}" 
@model EnglishCenter.Web.Pages.Enrollments.TransferModel
@{
    ViewData["Title"] = "Transfer Enrollment";
}

<h2>Transfer Enrollment</h2>

<form method="post">
    <div class="mb-3">
        <label class="form-label">Target Class</label>
        <select asp-for="Input.TargetClassId" class="form-select" asp-items="Model.Classes">
            <option value="">-- Select target class --</option>
        </select>
    </div>
    <div class="mb-3">
        <label class="form-label">Note</label>
        <textarea asp-for="Input.Note" class="form-control"></textarea>
    </div>

    <button class="btn btn-warning" type="submit">Transfer</button>
    <a asp-page="/Classes/Roster" asp-route-id="@Model.ClassId" class="btn btn-secondary">Back to Roster</a>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger mt-3">@Model.ErrorMessage</div>
    }
</form>