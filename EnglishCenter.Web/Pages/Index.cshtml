@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard Trung tâm Anh ngữ";
}

<section class="hero-section mb-4">
    <div>
        <h1 class="display-6 fw-bold mb-2">English Center Management Dashboard</h1>
        <p class="text-muted mb-0">Giao diện Razor Page đã kết nối trực tiếp với API để theo dõi lớp học, điểm danh và rủi ro học viên.</p>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger" role="alert">
        @Model.ErrorMessage
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-md-6 col-xl-3">
        <article class="summary-card">
            <p class="summary-label">Tổng số lớp</p>
            <p class="summary-value">@Model.Stats.TotalClasses</p>
        </article>
    </div>
    <div class="col-md-6 col-xl-3">
        <article class="summary-card">
            <p class="summary-label">Lớp đang hoạt động</p>
            <p class="summary-value">@Model.Stats.ActiveClasses</p>
        </article>
    </div>
    <div class="col-md-6 col-xl-3">
        <article class="summary-card">
            <p class="summary-label">Tỉ lệ điểm danh TB</p>
            <p class="summary-value">@Model.Stats.AverageAttendanceRate.ToString("0.##")%</p>
        </article>
    </div>
    <div class="col-md-6 col-xl-3">
        <article class="summary-card">
            <p class="summary-label">Học viên có rủi ro</p>
            <p class="summary-value">@Model.Stats.StudentsAtRisk</p>
        </article>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-7">
        <section class="dashboard-panel">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="h5 m-0">Hiệu suất lớp học</h2>
                <small class="text-muted">Nguồn: /api/AcademicDashboard/class-dashboard</small>
            </div>
            <div class="table-responsive">
                <table class="table align-middle table-hover">
                    <thead>
                        <tr>
                            <th>Mã lớp</th>
                            <th>Tên lớp</th>
                            <th>HV hiện tại</th>
                            <th>Buổi học</th>
                            <th>Tỉ lệ điểm danh</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.ClassDashboards.Any())
                    {
                        @foreach (var item in Model.ClassDashboards)
                        {
                            <tr>
                                <td class="fw-semibold">@item.ClassCode</td>
                                <td>@item.ClassName</td>
                                <td>@item.ActiveEnrollments/@item.MaxStudents</td>
                                <td>@item.UpcomingSessions/@item.TotalSessions</td>
                                <td>
                                    <span class="badge rounded-pill bg-success-subtle text-success-emphasis px-3 py-2">
                                        @item.AttendanceRate.ToString("0.##")%
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">Chưa có dữ liệu lớp học.</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>
    </div>

    <div class="col-xl-5">
        <section class="dashboard-panel">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="h5 m-0">Danh sách lớp gần đây</h2>
                <small class="text-muted">Nguồn: /api/Classes</small>
            </div>

            <div class="class-list">
                @if (Model.Classes.Any())
                {
                    @foreach (var item in Model.Classes)
                    {
                        <article class="class-item">
                            <div>
                                <p class="class-code mb-1">@item.ClassCode</p>
                                <p class="class-name mb-1">@item.Name</p>
                                <p class="class-meta mb-0">Sĩ số tối đa: @item.MaxStudents · Học phí: @item.TuitionFee.ToString("N0") VNĐ</p>
                            </div>
                            <span class="status-dot @(item.Status == 1 ? "active" : "inactive")"></span>
                        </article>
                    }
                }
                else
                {
                    <p class="text-muted mb-0">Chưa có lớp nào để hiển thị.</p>
                }
            </div>
        </section>
    </div>
</div>
