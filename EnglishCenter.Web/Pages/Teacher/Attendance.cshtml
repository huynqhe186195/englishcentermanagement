@page
@{
    ViewData["Title"] = "Attendance";
}

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Session</label>
                <select class="form-select">
                    <option>Session 01 - TOEIC-MOR-01</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label">Date</label>
                <input class="form-control" value="2026-05-22" readonly />
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button class="btn btn-success">Save Attendance</button>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white fw-semibold">Session Roster</div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Student Code</th>
                    <th>Full Name</th>
                    <th>Status</th>
                    <th>Note</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>1</td>
                    <td>ST001</td>
                    <td>Nguyen Van A</td>
                    <td>
                        <select class="form-select form-select-sm attendance-status">
                            <option value="present">Present</option>
                            <option value="absent">Absent</option>
                        </select>
                    </td>
                    <td><input class="form-control form-control-sm" placeholder="Optional note" /></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>