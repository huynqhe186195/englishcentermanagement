@page
@model EnglishCenter.Web.Pages.Teacher.MyClassesModel
@{
    ViewData["Title"] = "My Classes";
}

<h3 class="mb-3">Lớp tôi phụ trách</h3>

@if (!Model.TeacherId.HasValue)
{
    <div class="alert alert-warning">Không tìm thấy hồ sơ giáo viên cho tài khoản hiện tại.</div>
    return;
}

@if (!Model.ClassIds.Any())
{
    <div class="alert alert-info">Hiện chưa có lớp được phân công.</div>
    return;
}

<form method="get" class="mb-3 row g-3">
    <div class="col-md-4">
        <label class="form-label">Chọn lớp</label>
        <select name="ClassId" class="form-select" onchange="this.form.submit()">
            @foreach (var id in Model.ClassIds)
            {
                <option value="@id" selected="@(id == Model.ClassId)">Class #@id</option>
            }
        </select>
    </div>
</form>

@if (Model.SelectedSummary != null)
{
    <div class="row g-3 mb-4">
        <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="small text-muted">Sĩ số tối đa</div><h4>@Model.SelectedSummary.MaxStudents</h4></div></div></div>
        <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="small text-muted">Đang học</div><h4>@Model.SelectedSummary.ActiveEnrollments</h4></div></div></div>
        <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="small text-muted">Buổi hoàn thành</div><h4>@Model.SelectedSummary.CompletedSessions / @Model.SelectedSummary.TotalSessions</h4></div></div></div>
        <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="small text-muted">Tỷ lệ điểm danh</div><h4>@Model.SelectedSummary.AttendanceRate%</h4></div></div></div>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white fw-semibold">Class roster</div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light"><tr><th>Mã HV</th><th>Họ tên</th><th>Email</th><th>SĐT</th><th>Trạng thái</th></tr></thead>
            <tbody>
            @if (!Model.Roster.Any())
            {
                <tr><td colspan="5" class="text-center text-muted py-4">Lớp chưa có học viên.</td></tr>
            }
            else
            {
                @foreach (var item in Model.Roster)
                {
                    <tr>
                        <td>@item.StudentCode</td>
                        <td>@item.FullName</td>
                        <td>@item.Email</td>
                        <td>@item.Phone</td>
                        <td>@item.EnrollmentStatus</td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>
