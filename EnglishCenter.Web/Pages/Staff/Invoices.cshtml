@page
@model EnglishCenter.Web.Pages.Staff.InvoicesModel
@{
    ViewData["Title"] = "Staff - Invoices";
}

<div class="d-flex justify-content-between align-items-center mb-3"><h2>Invoices</h2></div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4"><input class="form-control" name="InvoiceNo" value="@Model.InvoiceNo" placeholder="Invoice No" /></div>
    <div class="col-md-3">
        <select class="form-select" name="Status">
            <option value="">All status</option>
            <option value="1" selected="@(Model.Status==1)">Unpaid</option>
            <option value="3" selected="@(Model.Status==3)">Paid</option>
            <option value="4" selected="@(Model.Status==4)">Cancelled</option>
        </select>
    </div>
    <div class="col-md-2"><button class="btn btn-outline-primary w-100">Filter</button></div>
</form>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white fw-semibold">Tạo invoice</div>
    <div class="card-body">
        <form method="post" asp-page-handler="Create" class="row g-2">
            <div class="col-md-3"><select class="form-select" asp-for="CreateInput.StudentId" asp-items="Model.Students"></select></div>
            <div class="col-md-4"><select class="form-select" asp-for="CreateInput.CourseId" asp-items="Model.Courses"></select></div>
            <div class="col-md-2"><input class="form-control" type="date" asp-for="CreateInput.DueDate" /></div>
            <div class="col-md-2"><input class="form-control" asp-for="CreateInput.Note" placeholder="Note" /></div>
            <div class="col-md-1"><button class="btn btn-primary w-100">Tạo</button></div>
        </form>
    </div>
</div>

<table class="table table-striped align-middle">
    <thead><tr><th>No</th><th>Student</th><th>Class</th><th>Final</th><th>Status</th><th></th></tr></thead>
    <tbody>
    @foreach (var x in Model.Items)
    {
        <tr>
            <td>@x.InvoiceNo</td>
            <td>@x.StudentId</td>
            <td>@(x.ClassId?.ToString() ?? "--")</td>
            <td>@x.FinalAmount.ToString("N0")</td>
            <td>@(x.Status==3?"Paid":x.Status==4?"Cancelled":"Unpaid")</td>
            <td>
                <a asp-page="/Staff/Payments" asp-route-invoiceId="@x.Id" class="btn btn-sm btn-outline-success">Payment</a>
                <a asp-page="/Staff/ClassSelection" asp-route-invoiceId="@x.Id" class="btn btn-sm btn-outline-primary">Select class</a>
            </td>
        </tr>
    }
    </tbody>
</table>
