@page
@{
    ViewData["Title"] = "Staff Dashboard";
}

<div class="row g-3 mb-4">
    <div class="col-md-4"><div class="card border-0 shadow-sm"><div class="card-body"><div class="text-muted small">Pending Class Selection</div><h3>12</h3></div></div></div>
    <div class="col-md-4"><div class="card border-0 shadow-sm"><div class="card-body"><div class="text-muted small">Invoices Today</div><h3>9</h3></div></div></div>
    <div class="col-md-4"><div class="card border-0 shadow-sm"><div class="card-body"><div class="text-muted small">Payments Today</div><h3>8</h3></div></div></div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white fw-semibold">Recent Transactions</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Invoice No</th>
                        <th>Student</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>INV-20260501-0001</td>
                        <td>Nguyen Van A</td>
                        <td>5,000,000</td>
                        <td><span class="badge bg-success">Paid</span></td>
                        <td><a asp-page="/Staff/ClassSelection" class="btn btn-sm btn-outline-primary">Select Class</a></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>