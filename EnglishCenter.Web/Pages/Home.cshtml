@page "/home"
@model HomeModel
@{
    ViewData["Title"] = "Home";
}

<section class="landing-hero mb-4">
    <div>
        <span class="hero-badge">English Center Platform</span>
        <h1 class="hero-title">Quản lý đa campus trong một hệ thống</h1>
        <p class="hero-subtitle">Trang Home là nơi chọn campus và đi nhanh đến các chức năng chính như Dashboard, Login, quản lý lớp học.</p>
        <div class="hero-actions">
            <a class="btn btn-primary" asp-page="/Dashboard" asp-route-selectedCampusId="@Model.SelectedCampus?.Id">Vào Dashboard</a>
            <a class="btn btn-outline-primary" asp-page="/Login">Đăng nhập</a>
        </div>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="row g-4">
    <div class="col-xl-5">
        <section class="glass-card h-100">
            <h2 class="h5 mb-3">Campus đang chọn</h2>

            @if (Model.SelectedCampus is not null)
            {
                <div class="campus-focus">
                    <p class="campus-code mb-1">@Model.SelectedCampus.CampusCode</p>
                    <h3 class="h4 mb-2">@Model.SelectedCampus.Name</h3>
                    <p class="mb-1 text-muted">📍 @Model.SelectedCampus.Address</p>
                    <p class="mb-3 text-muted">☎ @Model.SelectedCampus.Phone</p>
                    <a class="btn btn-sm btn-primary" asp-page="/Dashboard" asp-route-selectedCampusId="@Model.SelectedCampus.Id">Xem thống kê campus này</a>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">Chưa có dữ liệu campus.</p>
            }
        </section>
    </div>

    <div class="col-xl-7">
        <section class="glass-card h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="h5 m-0">Danh sách campus</h2>
                <small class="text-muted">Nhấn vào campus để chọn nhanh</small>
            </div>
            <div class="campus-grid">
                @if (Model.Campuses.Any())
                {
                    foreach (var campus in Model.Campuses)
                    {
                        var isActive = Model.SelectedCampus?.Id == campus.Id;
                        <a class="campus-card @(isActive ? "active" : string.Empty)" asp-page="/Home" asp-route-campusId="@campus.Id">
                            <p class="campus-code mb-1">@campus.CampusCode</p>
                            <h3 class="h6 mb-1">@campus.Name</h3>
                            <p class="campus-meta mb-1">@campus.Address</p>
                            <p class="campus-meta mb-0">@campus.Phone</p>
                        </a>
                    }
                }
                else
                {
                    <p class="text-muted mb-0">Không có campus để hiển thị.</p>
                }
            </div>
        </section>
    </div>
</div>
