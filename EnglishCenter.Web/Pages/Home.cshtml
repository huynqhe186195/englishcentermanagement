@page "/home"
@model HomeModel
@{
    ViewData["Title"] = "English Center Courses";
}

<section class="courses-landing mb-5">
    <div class="hero-content text-center">
        <span class="hero-pill">English Center • Khóa học khai giảng</span>
        <h1>Chọn khóa học phù hợp cho từng mục tiêu tiếng Anh</h1>
        <p>Danh sách khóa học đang mở từ hệ thống quản lý trung tâm. Theo dõi lịch khai giảng, học phí và sĩ số trực tiếp theo dữ liệu thật.</p>
        <div class="hero-cta">
            <a class="btn btn-light btn-lg" asp-page="/Login">Đăng nhập tư vấn viên</a>
            <a class="btn btn-outline-light btn-lg" asp-page="/Dashboard">Xem Dashboard vận hành</a>
        </div>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<section>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h3 mb-0">Danh sách khóa học</h2>
        <span class="text-muted">@Model.Courses.Count khóa học</span>
    </div>

    <div class="course-grid">
        @if (Model.Courses.Any())
        {
            foreach (var course in Model.Courses)
            {
                <article class="course-card">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <span class="course-code">@course.ClassCode</span>
                        <span class="status-pill @(course.Status == 1 ? "status-open" : "status-close")">@(course.Status == 1 ? "Đang tuyển sinh" : "Ngừng nhận")</span>
                    </div>

                    <h3 class="h5 mb-2">@course.Title</h3>
                    <p class="course-meta mb-1">🗓 @course.StartDate:dd/MM/yyyy - @course.EndDate:dd/MM/yyyy</p>
                    <p class="course-meta mb-1">👥 Sĩ số tối đa: @course.MaxStudents học viên</p>
                    <p class="course-fee mb-3">💳 Học phí: @course.TuitionFee.ToString("N0") VNĐ</p>

                    <button type="button" class="btn btn-primary w-100" disabled>Đăng ký tư vấn</button>
                </article>
            }
        }
        else
        {
            <div class="empty-course">Hiện chưa có khóa học nào để hiển thị.</div>
        }
    </div>
</section>
