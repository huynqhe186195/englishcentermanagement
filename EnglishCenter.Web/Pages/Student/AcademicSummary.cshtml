@page "{studentId:long}"
@model EnglishCenter.Web.Pages.Student.AcademicSummaryModel
@{
    ViewData["Title"] = "Academic Summary";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Academic Summary</h2>
    <a class="btn btn-secondary" asp-page="/Student/Index">Back to Dashboard</a>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Enrollments</h5>
                <p>Active: @Model.Summary.ActiveEnrollments</p>
                <p>Suspended: @Model.Summary.SuspendedEnrollments</p>
                <p>Completed: @Model.Summary.CompletedEnrollments</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Attendance</h5>
                <p>Total records: @Model.Summary.TotalAttendanceRecords</p>
                <p>Present: @Model.Summary.PresentCount</p>
                <p>Absent: @Model.Summary.AbsentCount</p>
                <p>Attendance Rate: @Model.Summary.AttendanceRate%</p>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <h4>Upcoming Sessions: @Model.Summary.UpcomingSessions</h4>
    <a class="btn btn-outline-primary" asp-page="/Enrollments/Index">View Enrollments</a>
</div>