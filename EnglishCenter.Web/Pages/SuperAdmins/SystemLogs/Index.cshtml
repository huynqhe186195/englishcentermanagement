@page
@model EnglishCenter.Web.Pages.SuperAdmins.SystemLogs.IndexModel
@{
    Layout = "~/Pages/Shared/_SuperAdminLayout.cshtml";
    ViewData["Title"] = "System Logs";
}

<div class="page-header">
    <div>
        <h2 class="page-title">System Logs</h2>
        <p class="page-subtitle">Theo dõi log hệ thống và các hành động nhạy cảm.</p>
    </div>
    <div>
        <button class="btn btn-outline-primary">Export Logs</button>
    </div>
</div>

<div class="card sa-card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-3">
                <input type="text" class="form-control" name="Keyword" value="@Model.Keyword" placeholder="Search action" />
            </div>
            <div class="col-md-3">
                <select class="form-select" name="Module">
                    <option>All Modules</option>
                    <option value="Users">Users</option>
                    <option value="Invoices">Invoices</option>
                    <option value="Enrollments">Enrollments</option>
                    <option value="ClassSessions">ClassSessions</option>
                </select>
            </div>
            <div class="col-md-6">
                <button class="btn btn-outline-secondary w-100">Apply Filter</button>
            </div>
        </form>
    </div>
</div>

<div class="card sa-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table sa-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Time</th>
                        <th>Module</th>
                        <th>Action</th>
                        <th>IP</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Logs.Any())
                    {
                        <tr><td colspan="4" class="text-center text-muted py-4">No logs found.</td></tr>
                    }
                    else
                    {
                        @foreach (var log in Model.Logs)
                        {
                            <tr>
                                <td>@log.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@log.EntityName</td>
                                <td>@log.Action</td>
                                <td>@(string.IsNullOrWhiteSpace(log.IpAddress) ? "-" : log.IpAddress)</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
