@page
@model EnglishCenter.Web.Pages.SuperAdmins.DashboardModel
@{
    Layout = "~/Pages/Shared/_SuperAdminLayout.cshtml";
    ViewData["Title"] = "Users";
}

<div class="page-header">
    <div>
        <h2 class="page-title">Users</h2>
        <p class="page-subtitle">Quản lý người dùng toàn hệ thống.</p>
    </div>
    <div>
        <button class="btn btn-primary">+ Add User</button>
    </div>
</div>

<div class="card sa-card mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <input type="text" class="form-control" placeholder="Search name or email" />
            </div>
            <div class="col-md-3">
                <select class="form-select">
                    <option>All Campuses</option>
                    <option>District 1</option>
                    <option>Thu Duc</option>
                    <option>Binh Thanh</option>
                </select>
            </div>
            <div class="col-md-3">
                <select class="form-select">
                    <option>All Roles</option>
                    <option>SuperAdmin</option>
                    <option>Campus Manager</option>
                    <option>Staff</option>
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-secondary w-100">Filter</button>
            </div>
        </div>
    </div>
</div>

<div class="card sa-card">
    <div class="card-header card-header-clean d-flex justify-content-between align-items-center">
        <h5 class="mb-0">User List</h5>
        <button class="btn btn-sm btn-outline-primary">Export</button>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table sa-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Campus</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Created Date</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Nguyen Van A</td>
                        <td>vana@example.com</td>
                        <td>District 1</td>
                        <td>Campus Manager</td>
                        <td><span class="badge badge-soft-success">Active</span></td>
                        <td>2026-03-01</td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary">Edit</button>
                            <button class="btn btn-sm btn-outline-warning">Lock</button>
                            <button class="btn btn-sm btn-outline-danger btn-delete" data-name="Nguyen Van A">Delete</button>
                        </td>
                    </tr>
                    <tr>
                        <td>Tran Thi B</td>
                        <td>thib@example.com</td>
                        <td>Thu Duc</td>
                        <td>Staff</td>
                        <td><span class="badge badge-soft-success">Active</span></td>
                        <td>2026-02-18</td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary">Edit</button>
                            <button class="btn btn-sm btn-outline-warning">Lock</button>
                            <button class="btn btn-sm btn-outline-danger btn-delete" data-name="Tran Thi B">Delete</button>
                        </td>
                    </tr>
                    <tr>
                        <td>Le Van C</td>
                        <td>vanc@example.com</td>
                        <td>Binh Thanh</td>
                        <td>Staff</td>
                        <td><span class="badge badge-soft-danger">Inactive</span></td>
                        <td>2026-01-29</td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary">Edit</button>
                            <button class="btn btn-sm btn-outline-success">Unlock</button>
                            <button class="btn btn-sm btn-outline-danger btn-delete" data-name="Le Van C">Delete</button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>