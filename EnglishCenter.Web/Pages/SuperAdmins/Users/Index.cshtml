@page
@model EnglishCenter.Web.Pages.SuperAdmins.Users.IndexModel
@{
    Layout = "~/Pages/Shared/_SuperAdminLayout.cshtml";
    ViewData["Title"] = "Users";
}

<div class="page-header">
    <div>
        <h2 class="page-title">Users</h2>
        <p class="page-subtitle">Danh sách người dùng (view-only) toàn hệ thống.</p>
    </div>
</div>

<div class="card sa-card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-5">
                <input type="text" class="form-control" name="Keyword" value="@Model.Keyword" placeholder="Search name / username / email" />
            </div>
            <div class="col-md-3">
                <select class="form-select">
                    <option>All Campuses</option>
                    @foreach (var c in Model.Campuses)
                    {
                        <option>@c.Name (@c.CampusCode)</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <select class="form-select" name="RoleId">
                    <option value="">All Roles</option>
                    @foreach (var r in Model.Roles)
                    {
                        <option value="@r.Id" selected="@(Model.RoleId == r.Id)">@r.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-secondary w-100">Filter</button>
            </div>
        </form>
    </div>
</div>

<div class="card sa-card">
    <div class="card-header card-header-clean d-flex justify-content-between align-items-center">
        <h5 class="mb-0">User List</h5>
        <span class="text-muted small">Total: @Model.TotalRecords</span>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table sa-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Full Name</th>
                        <th>Username</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Created Date</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Users.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">No users found.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td>@user.FullName</td>
                                <td>@user.UserName</td>
                                <td>@(string.IsNullOrWhiteSpace(user.Email) ? "-" : user.Email)</td>
                                <td>@user.RoleName</td>
                                <td>
                                    <span class="badge @(user.Status == 1 ? "badge-soft-success" : "badge-soft-danger")">
                                        @(user.Status == 1 ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td>@(user.CreatedAt?.ToString("yyyy-MM-dd") ?? "-")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination pagination-sm">
            @for (var p = 1; p <= Model.TotalPages; p++)
            {
                <li class="page-item @(p == Model.PageNumber ? "active" : string.Empty)">
                    <a class="page-link" href="?PageNumber=@p&Keyword=@Model.Keyword&RoleId=@Model.RoleId">@p</a>
                </li>
            }
        </ul>
    </nav>
}
