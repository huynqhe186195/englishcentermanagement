@page
@model EnglishCenter.Web.Pages.SuperAdmins.Campuses.IndexModel
@{
    Layout = "~/Pages/Shared/_SuperAdminLayout.cshtml";
    ViewData["Title"] = "Campuses";
}

<div class="page-header">
    <div>
        <h2 class="page-title">Campuses</h2>
        <p class="page-subtitle">Quản lý tất cả campus trong hệ thống.</p>
    </div>
    <div>
        <button class="btn btn-primary">+ Add Campus</button>
    </div>
</div>

<div class="card sa-card">
    <div class="card-header card-header-clean d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Campus Management</h5>
        <button class="btn btn-sm btn-outline-primary">Export</button>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table sa-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Campus Name</th>
                        <th>Campus Code</th>
                        <th>Revenue</th>
                        <th>Invoices</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Campuses.Any())
                    {
                        <tr><td colspan="4" class="text-center text-muted py-4">No campuses found.</td></tr>
                    }
                    else
                    {
                        @foreach (var c in Model.Campuses)
                        {
                            <tr>
                                <td>@c.CampusName</td>
                                <td>@c.CampusCode</td>
                                <td>@c.Revenue.ToString("N0")</td>
                                <td>@c.InvoiceCount</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
