@page
@model EnglishCenter.Web.Pages.SuperAdmins.Roles.IndexModel
@{
    Layout = "~/Pages/Shared/_SuperAdminLayout.cshtml";
    ViewData["Title"] = "Roles";

    var currentIds = Model.CurrentPermissions.Select(x => x.PermissionId).ToHashSet();
}

<div class="page-header">
    <div>
        <h2 class="page-title">Roles</h2>
        <p class="page-subtitle">Role/Permission governance: diff & preview impact.</p>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.SaveMessage))
{
    <div class="alert @(Model.SaveSuccess ? "alert-success" : "alert-danger")">@Model.SaveMessage</div>
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card sa-card h-100">
            <div class="card-header card-header-clean">
                <h5 class="mb-0">Role List</h5>
            </div>
            <div class="card-body">
                <form method="get">
                    <select class="form-select" name="RoleId" onchange="this.form.submit()">
                        @foreach (var role in Model.Roles)
                        {
                            <option value="@role.Id" selected="@(Model.RoleId == role.Id)">@role.Name (@role.Code)</option>
                        }
                    </select>
                </form>

                <hr />
                <h6 class="mb-2">Preview Impact</h6>
                <p class="mb-1"><strong>Affected users:</strong> @Model.Impact.TotalUsers</p>
                <ul class="small mb-0">
                    @foreach (var u in Model.Impact.Users)
                    {
                        <li>@u.FullName (@u.UserName)</li>
                    }
                </ul>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card sa-card">
            <div class="card-header card-header-clean d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Permission Matrix</h5>
                <div class="small text-muted">
                    <span class="me-2">Added: <strong id="diff-added">0</strong></span>
                    <span>Removed: <strong id="diff-removed">0</strong></span>
                </div>
            </div>
            <div class="card-body">
                <form method="post" asp-page-handler="Save" id="permission-form">
                    <input type="hidden" name="RoleId" value="@Model.RoleId" />

                    <div class="row g-2">
                        @foreach (var p in Model.CatalogPermissions)
                        {
                            var isCurrent = currentIds.Contains(p.PermissionId);
                            <div class="col-md-6">
                                <label class="form-check">
                                    <input class="form-check-input permission-toggle"
                                           type="checkbox"
                                           name="SelectedPermissionIds"
                                           value="@p.PermissionId"
                                           data-original="@(isCurrent ? "1" : "0")"
                                           checked="@isCurrent" />
                                    <span class="form-check-label">
                                        <strong>@p.PermissionCode</strong>
                                        <span class="text-muted">- @p.PermissionName</span>
                                    </span>
                                </label>
                            </div>
                        }
                    </div>

                    <div class="mt-3 p-2 border rounded bg-light">
                        <div class="fw-semibold mb-1">Diff preview</div>
                        <div class="small">
                            <div><strong>Added permissions:</strong> <span id="added-list">-</span></div>
                            <div><strong>Removed permissions:</strong> <span id="removed-list">-</span></div>
                            <div class="mt-1 text-muted">
                                If saved, this change affects <strong>@Model.Impact.TotalUsers</strong> users currently assigned this role.
                            </div>
                        </div>
                    </div>

                    <button class="btn btn-primary mt-3" type="submit">Save Changes</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        const toggles = Array.from(document.querySelectorAll('.permission-toggle'));
        const addedCount = document.getElementById('diff-added');
        const removedCount = document.getElementById('diff-removed');
        const addedList = document.getElementById('added-list');
        const removedList = document.getElementById('removed-list');

        function updateDiff() {
            const added = [];
            const removed = [];

            toggles.forEach(cb => {
                const original = cb.dataset.original === '1';
                const current = cb.checked;
                const code = cb.parentElement.querySelector('strong')?.innerText ?? cb.value;

                if (!original && current) added.push(code);
                if (original && !current) removed.push(code);
            });

            addedCount.textContent = String(added.length);
            removedCount.textContent = String(removed.length);
            addedList.textContent = added.length ? added.join(', ') : '-';
            removedList.textContent = removed.length ? removed.join(', ') : '-';
        }

        toggles.forEach(cb => cb.addEventListener('change', updateDiff));
        updateDiff();
    })();
</script>
