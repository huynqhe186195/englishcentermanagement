@{
    var title = ViewData["Title"]?.ToString() ?? "SuperAdmin";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - English Center Management</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/superadmin.css" asp-append-version="true" />
</head>
<body>
    <div class="sa-wrapper">
        <aside class="sa-sidebar" id="saSidebar">
            @await Html.PartialAsync("_SidebarSuperAdmin")
        </aside>

        <div class="sa-main">
            @await Html.PartialAsync("_TopbarSuperAdmin")

            <main class="sa-content container-fluid">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/superadmin.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>