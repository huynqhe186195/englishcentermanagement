@{
    var isSuperAdmin = User.IsInRole("SUPER_ADMIN");
    var isAdmin = User.IsInRole("ADMIN") || User.IsInRole("CENTER_ADMIN") || User.IsInRole("MANAGER");
    var isStaff = User.IsInRole("STAFF");
    var isTeacher = User.IsInRole("TEACHER");
    var isStudent = User.IsInRole("STUDENT");
}

<ul class="nav nav-pills flex-column gap-1">
    @if (isSuperAdmin)
    {
        <li class="nav-item"><a class="nav-link text-white" asp-page="/SuperAdmin/Dashboard"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a></li>
        <li class="nav-item"><a class="nav-link text-white" asp-page="/SuperAdmin/Users"><i class="bi bi-people me-2"></i>Users</a></li>
        <li class="nav-item"><a class="nav-link text-white" asp-page="/SuperAdmin/Roles"><i class="bi bi-shield-lock me-2"></i>Roles & Permissions</a></li>
        <li class="nav-item"><a class="nav-link text-white" asp-page="/SuperAdmin/Campuses"><i class="bi bi-buildings me-2"></i>Campuses</a></li>
        <li class="nav-item"><a class="nav-link text-white" asp-page="/FinancialDashboard/revenue-summary"><i class="bi bi-cash-stack me-2"></i>Financial Dashboard</a></li>
    }

    @if (isAdmin)
    {
        <li class="nav-item"><a class="nav-link text-white" asp-page="/Admin/Dashboard">Dashboard</a></li>
        <li class="nav-item"><a class="nav-link text-white" asp-page="/Admin/Students">Students</a></li>
        <li class="nav-item"><a class="nav-link text-white" asp-page="/Admin/Teachers">Teachers</a></li>
        <li class="nav-item"><a class="nav-link text-white" asp-page="/Admin/Courses">Courses</a></li>
        <li class="nav-item"><a class="nav-link text-white" asp-page="/Admin/Classes">Classes</a></li>
        <li class="nav-item"><a class="nav-link text-white" asp-page="/Admin/Sessions">Sessions</a></li>
        <li class="nav-item"><a class="nav-link text-white" asp-page="/Admin/Rooms">Rooms</a></li>
        <li class="nav-item"><a class="nav-link text-white" asp-page="/Admin/Enrollments">Enrollments</a></li>
        <li class="nav-item"><a class="nav-link text-white" asp-page="/Admin/Financial">Financial</a></li>
    }

    @if (isStaff)
    {
        <li class="nav-item"><a class="nav-link text-white" asp-page="/Staff/Dashboard">Dashboard</a></li>
        <li class="nav-item"><a class="nav-link text-white" asp-page="/Staff/Invoices">Invoices</a></li>
        <li class="nav-item"><a class="nav-link text-white" asp-page="/Staff/Payments">Payments</a></li>
        <li class="nav-item"><a class="nav-link text-white" asp-page="/Staff/ClassSelection">Class Selection</a></li>
        <li class="nav-item"><a class="nav-link text-white" asp-page="/Staff/Enrollments">Enrollments</a></li>
    }

    @if (isTeacher)
    {
        <li class="nav-item"><a class="nav-link text-white" asp-page="/Teacher/Dashboard">Dashboard</a></li>
        <li class="nav-item"><a class="nav-link text-white" asp-page="/Teacher/Timetable">Timetable</a></li>
        <li class="nav-item"><a class="nav-link text-white" asp-page="/Teacher/MyClasses">My Classes</a></li>
        <li class="nav-item"><a class="nav-link text-white" asp-page="/Teacher/Attendance">Attendance</a></li>
    }

    @if (isStudent)
    {
        <li class="nav-item"><a class="nav-link text-white" asp-page="/Student/Dashboard">Dashboard</a></li>
        <li class="nav-item"><a class="nav-link text-white" asp-page="/Student/Timetable">Timetable</a></li>
        <li class="nav-item"><a class="nav-link text-white" asp-page="/Student/AttendanceReport">Attendance Report</a></li>
        <li class="nav-item"><a class="nav-link text-white" asp-page="/Student/Invoices">Invoices</a></li>
        <li class="nav-item"><a class="nav-link text-white" asp-page="/Student/Payments">Payments</a></li>
        <li class="nav-item"><a class="nav-link text-white" asp-page="/Student/SelectClass">Select Class</a></li>
    }
</ul>