<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EnglishCenter.Web</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EnglishCenter.Web.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        var hideChrome = (ViewData["HideChrome"] as bool?) == true;
    }
    @if (!hideChrome)
    {
        <header>
            <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
                <div class="container">
                    <a class="navbar-brand" asp-area="" asp-page="/Index">EnglishCenter.Web</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-page="/Index">Home</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-page="/Privacy">Privacy</a>
                            </li>
                        </ul>
                        <ul class="navbar-nav">
                            @if (!string.IsNullOrEmpty(Context.Session?.GetString("AccessToken")))
                            {
                                <li class="nav-item"><a class="nav-link" asp-page="/Admin/Index">Admin</a></li>
                                <li class="nav-item"><a class="nav-link" asp-page="/Admin/Users/Index" asp-route-RoleCode="TEACHER">Teacher Mgmt</a></li>
                                <li class="nav-item"><a class="nav-link" asp-page="/Admin/Users/Index" asp-route-RoleCode="STUDENT">Student Mgmt</a></li>
                                <li class="nav-item"><a class="nav-link" asp-page="/Classes/Index">Classes</a></li>
                                <li class="nav-item"><a class="nav-link" asp-page="/Enrollments/Index">Enrollments</a></li>
                                <li class="nav-item"><a class="nav-link" asp-page="/Account/Logout">Logout</a></li>
                            }
                            else
                            {
                                <li class="nav-item"><a class="nav-link" asp-page="/Account/Login">Login</a></li>
                            }
                        </ul>
                    </div>
                </div>
            </nav>
        </header>
    }
    <div class="layout-content @(hideChrome ? "" : "container")">
        <main role="main" class="@(hideChrome ? "" : "pb-3")">
            @RenderBody()
        </main>
    </div>
    @if (!hideChrome)
    {
        <footer class="border-top footer text-muted">
            <div class="container">
                © 2026 - EnglishCenter.Web - <a asp-area="" asp-page="/Privacy">Privacy</a>
            </div>
        </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <div class="position-fixed top-0 end-0 p-3" style="z-index: 10800;">
        <div id="toastContainer"></div>
    </div>

    <script>
        function escapeHtml(unsafe) {
            return unsafe
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/\"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        function showToast(message, type) {
            var bg = 'bg-info';
            var textClass = '';
            if (type === 'success') { bg = 'bg-success text-white'; }
            else if (type === 'error') { bg = 'bg-danger text-white'; }
            else if (type === 'warning') { bg = 'bg-warning text-dark'; }

            var toastId = 'toast-' + Date.now();
            var html = '<div id="' + toastId + '" class="toast align-items-center ' + bg + ' border-0 mb-2" role="alert" aria-live="assertive" aria-atomic="true">'
                + '<div class="d-flex">'
                + '<div class="toast-body">' + escapeHtml(message) + '</div>'
                + '<button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>'
                + '</div></div>';

            var container = document.getElementById('toastContainer');
            if (!container) return;
            container.insertAdjacentHTML('beforeend', html);
            var toastEl = document.getElementById(toastId);
            var toast = new bootstrap.Toast(toastEl, { delay: 5000 });
            toast.show();
            // remove after hidden
            toastEl.addEventListener('hidden.bs.toast', function () { toastEl.remove(); });
        }
    </script>

    @if (TempData["ToastMessage"] != null)
    {
        var msgJson = System.Text.Json.JsonSerializer.Serialize(TempData["ToastMessage"].ToString());
        var typeJson = System.Text.Json.JsonSerializer.Serialize((TempData["ToastType"] ?? "info").ToString());
        <text>
            <script>
                document.addEventListener('DOMContentLoaded', function() {
                    try {
                        showToast(@Html.Raw(msgJson), @Html.Raw(typeJson));
                    } catch (e) { console.error(e); }
                });
            </script>
        </text>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
