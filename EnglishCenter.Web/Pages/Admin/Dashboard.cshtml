@page
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="row g-3 mb-4">
    <div class="col-md-6 col-xl-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="text-muted small">Students</div><h3>540</h3></div></div></div>
    <div class="col-md-6 col-xl-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="text-muted small">Teachers</div><h3>28</h3></div></div></div>
    <div class="col-md-6 col-xl-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="text-muted small">Classes</div><h3>41</h3></div></div></div>
    <div class="col-md-6 col-xl-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="text-muted small">Sessions Today</div><h3>17</h3></div></div></div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold">Classes Requiring Attention</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Class</th>
                                <th>Teacher</th>
                                <th>Students</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>IELTS-EVE-01</td>
                                <td>Ms. Anna</td>
                                <td>10/10</td>
                                <td><span class="badge bg-warning text-dark">Need Room Change</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold">Quick Actions</div>
            <div class="card-body d-grid gap-2">
                <a asp-page="/Admin/Users/Index" class="btn btn-primary">Manage Campus Users</a>
                <a asp-page="/Admin/Classes" class="btn btn-outline-primary">Manage Classes</a>
                <a asp-page="/Admin/Sessions" class="btn btn-outline-primary">Manage Sessions</a>
                <a asp-page="/Admin/Financial" class="btn btn-outline-success">View Financial Dashboard</a>
            </div>
        </div>
    </div>
</div>