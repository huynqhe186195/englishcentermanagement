@page
@model EnglishCenter.Web.Pages.Admin.Users.CreateStudentProfileModel
@{
    ViewData["Title"] = "Create Student Profile";
}

<section class="admin-page-header mb-4">
    <div>
        <span class="admin-badge-soft">Admin · Student Profile</span>
        <h1>Create Student Profile</h1>
        <p>Hoàn thiện hồ sơ học viên sau khi tạo tài khoản.</p>
    </div>
    <div class="admin-page-actions">
        <a class="btn btn-outline-primary" asp-page="/Admin/Users/Index">Về Campus Users</a>
    </div>
</section>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}
@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (!Model.IsCenterAdmin)
{
    <div class="alert alert-warning">
        Chức năng này chỉ dành cho CENTER_ADMIN.
    </div>
}
else
{
    <section class="admin-surface mb-4">
        <div class="admin-surface-head mb-2">
            <div>
                <h2>Student Profile Information</h2>
                <p>Nhập đầy đủ thông tin hồ sơ học viên cho tài khoản vừa tạo.</p>
            </div>
        </div>

        <form method="post" class="row g-3 admin-form-grid">
            <input asp-for="Input.UserId" type="hidden" />

            <div class="col-md-6">
                <label class="form-label">Full Name</label>
                <input asp-for="Input.FullName" class="form-control" required />
            </div>

            <div class="col-md-3">
                <label class="form-label">Date Of Birth</label>
                <input asp-for="Input.DateOfBirth" type="date" class="form-control" required />
            </div>

            <div class="col-md-3">
                <label class="form-label">Gender</label>
                <select asp-for="Input.Gender" class="form-select">
                    <option value="0">Female</option>
                    <option value="1">Male</option>
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label">Phone</label>
                <input asp-for="Input.Phone" class="form-control" />
            </div>

            <div class="col-md-4">
                <label class="form-label">Email</label>
                <input asp-for="Input.Email" type="email" class="form-control" />
            </div>

            <div class="col-md-4">
                <label class="form-label">School Name</label>
                <input asp-for="Input.SchoolName" class="form-control" required />
            </div>

            <div class="col-md-4">
                <label class="form-label">English Level</label>
                <input asp-for="Input.EnglishLevel" class="form-control" required />
            </div>

            <div class="col-md-8">
                <label class="form-label">Note</label>
                <input asp-for="Input.Note" class="form-control" />
            </div>

            <div class="col-md-2">
                <label class="form-label">Status</label>
                <select asp-for="Input.Status" class="form-select">
                    <option value="1">Active</option>
                    <option value="0">Inactive</option>
                </select>
            </div>

            <div class="col-md-3 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">Create Student Profile</button>
            </div>

            <div class="col-md-3 d-flex align-items-end">
                <a asp-page="/Admin/Users/Index" class="btn btn-outline-secondary w-100">Cancel</a>
            </div>
        </form>
    </section>
}