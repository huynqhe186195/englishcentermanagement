@page
@model EnglishCenter.Web.Pages.Admin.Users.IndexModel
@{
    ViewData["Title"] = "Campus Users";
}

<section class="admin-page-header mb-4">
    <div>
        <span class="admin-badge-soft">Admin · User Governance</span>
        <h1>Campus Users</h1>
        <p>Quản lý người dùng nội bộ trong campus, phân vai trò và kiểm soát trạng thái hoạt động.</p>
    </div>
    <div class="admin-page-actions">
        <a class="btn btn-primary" href="#create-user-form">Tạo người dùng</a>
        <a class="btn btn-outline-primary" asp-page="/Admin/Index">Về dashboard</a>
    </div>
</section>



<section class="admin-surface mb-3">
    <div class="d-flex align-items-center flex-wrap gap-2">
        <span class="text-muted small">Lọc nhanh theo role:</span>
        <a class="btn btn-sm @(string.IsNullOrWhiteSpace(Model.RoleCode) ? "btn-primary" : "btn-outline-primary")" asp-page="./Index">Tất cả</a>
        <a class="btn btn-sm @(string.Equals(Model.RoleCode, "TEACHER", System.StringComparison.OrdinalIgnoreCase) ? "btn-primary" : "btn-outline-primary")" asp-page="./Index" asp-route-RoleCode="TEACHER">Teacher</a>
        <a class="btn btn-sm @(string.Equals(Model.RoleCode, "STUDENT", System.StringComparison.OrdinalIgnoreCase) ? "btn-primary" : "btn-outline-primary")" asp-page="./Index" asp-route-RoleCode="STUDENT">Student</a>
    </div>
</section>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}
@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (!Model.IsCenterAdmin)
{
    <div class="alert alert-warning">
        Chức năng này chỉ dành cho CENTER_ADMIN. Tài khoản hiện tại không có quyền truy cập.
    </div>
}
else
{
    <section class="admin-surface mb-4" id="create-user-form">
        <div class="admin-surface-head mb-2">
            <div>
                <h2>Create User</h2>
                <p>Tạo tài khoản mới trong campus hiện tại.</p>
            </div>
        </div>
        <form method="post" asp-page-handler="Create" class="row g-3 admin-form-grid">
            <div class="col-md-4">
                <label class="form-label">UserName</label>
                <input asp-for="CreateInput.UserName" class="form-control" required />
            </div>
            <div class="col-md-4">
                <label class="form-label">Password</label>
                <input asp-for="CreateInput.PasswordHash" class="form-control" required />
            </div>
            <div class="col-md-4">
                <label class="form-label">Full Name</label>
                <input asp-for="CreateInput.FullName" class="form-control" required />
            </div>
            <div class="col-md-4">
                <label class="form-label">Email</label>
                <input asp-for="CreateInput.Email" type="email" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Phone</label>
                <input asp-for="CreateInput.PhoneNumber" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Status</label>
                <select asp-for="CreateInput.Status" class="form-select">
                    <option value="1">Active</option>
                    <option value="0">Inactive</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Role</label>
                <select asp-for="SelectedRoleId" class="form-select" required>
                    <option value="">-- Chọn role --</option>
                    @foreach (var role in Model.RoleOptions)
                    {
                        <option value="@role.Value">@role.Text</option>
                    }
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">Create</button>
            </div>
        </form>
    </section>

    @if (Model.EditingUser != null)
    {
        <section class="admin-surface mb-4">
            <div class="admin-surface-head mb-2">
                <div>
                    <h2>Edit User - @Model.EditingUser.UserName</h2>
                    <p>Cập nhật thông tin và trạng thái người dùng.</p>
                </div>
                <a class="btn btn-sm btn-outline-secondary" asp-page="./Index">Cancel</a>
            </div>
            <form method="post" asp-page-handler="Update" class="row g-3 admin-form-grid">
                <input asp-for="UpdateInput.Id" type="hidden" value="@Model.EditingUser.Id" />
                <div class="col-md-4">
                    <label class="form-label">Full Name</label>
                    <input asp-for="UpdateInput.FullName" class="form-control" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Email</label>
                    <input asp-for="UpdateInput.Email" type="email" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Phone</label>
                    <input asp-for="UpdateInput.PhoneNumber" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Password (optional)</label>
                    <input asp-for="UpdateInput.PasswordHash" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Status</label>
                    <select asp-for="UpdateInput.Status" class="form-select">
                        <option value="1">Active</option>
                        <option value="0">Inactive</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Save</button>
                </div>
            </form>
        </section>
    }

    <section class="admin-surface mb-4">
        <div class="admin-surface-head mb-2">
            <div>
                <h2>Campus User List</h2>
                <p>Tổng số bản ghi: @Model.TotalRecords</p>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table admin-modern-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Full Name</th>
                        <th>UserName</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Users.Any())
                    {
                        <tr><td colspan="6" class="text-center text-muted py-4">No users found.</td></tr>
                    }
                    else
                    {
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td>@user.FullName</td>
                                <td>@user.UserName</td>
                                <td>@(string.IsNullOrWhiteSpace(user.Email) ? "-" : user.Email)</td>
                                <td><span class="badge text-bg-light border">@(Model.UserRoleBadges.TryGetValue(user.Id, out var roleCode) ? roleCode : "-")</span></td>
                                <td>
                                    <span class="badge @(user.Status == 1 ? "text-bg-success" : "text-bg-secondary")">
                                        @(user.Status == 1 ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary" asp-page="./Index" asp-route-EditId="@user.Id" asp-route-RoleCode="@Model.RoleCode">Edit</a>
                                    <a class="btn btn-sm btn-outline-secondary" asp-page="./Index" asp-route-RoleUserId="@user.Id" asp-route-RoleCode="@Model.RoleCode">Roles</a>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@user.Id" class="d-inline"
                                          onsubmit="return confirm('Delete user @user.UserName?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </section>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-3 mb-4">
            <ul class="pagination pagination-sm admin-pagination">
                @for (var p = 1; p <= Model.TotalPages; p++)
                {
                    <li class="page-item @(p == Model.PageNumber ? "active" : string.Empty)">
                        <a class="page-link" href="?PageNumber=@p&RoleCode=@Model.RoleCode">@p</a>
                    </li>
                }
            </ul>
        </nav>
    }

    if (Model.RoleTargetUser != null)
    {
        <section class="admin-surface mt-4">
            <div class="admin-surface-head mb-2">
                <div>
                    <h2>Manage Roles - @Model.RoleTargetUser.UserName</h2>
                    <p>Whitelist cho CENTER_ADMIN: STAFF / TEACHER / PARENT / STUDENT.</p>
                </div>
                <a class="btn btn-sm btn-outline-secondary" asp-page="./Index">Close</a>
            </div>

            <h6>Current Roles</h6>
            @if (!Model.CurrentRoles.Any())
            {
                <p class="text-muted">User chưa có role.</p>
            }
            else
            {
                <div class="mb-3 d-flex flex-wrap gap-2">
                    @foreach (var role in Model.CurrentRoles)
                    {
                        <form method="post" asp-page-handler="RemoveRole" class="d-inline">
                            <input type="hidden" name="removeUserId" value="@Model.RoleTargetUser.Id" />
                            <input type="hidden" name="removeRoleId" value="@role.RoleId" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                @role.RoleCode (#@role.RoleId) ✕
                            </button>
                        </form>
                    }
                </div>
            }

            <div class="row g-3">
                <div class="col-md-6">
                    <h6>Assign 1 role (RoleId)</h6>
                    <form method="post" asp-page-handler="AssignRole" class="row g-2">
                        <input type="hidden" asp-for="AssignInput.UserId" value="@Model.RoleTargetUser.Id" />
                        <div class="col-8">
                            <input asp-for="AssignInput.RoleId" type="number" min="1" class="form-control" placeholder="Nhập RoleId" required />
                        </div>
                        <div class="col-4">
                            <button type="submit" class="btn btn-outline-primary w-100">Assign</button>
                        </div>
                    </form>
                </div>
                <div class="col-md-6">
                    <h6>Replace roles (comma RoleIds)</h6>
                    <form method="post" asp-page-handler="ReplaceRoles" class="row g-2">
                        <input type="hidden" asp-for="ReplaceInput.UserId" value="@Model.RoleTargetUser.Id" />
                        <div class="col-8">
                            <input asp-for="ReplaceRoleIdsText" class="form-control" placeholder="Ví dụ: 2,3,4" />
                        </div>
                        <div class="col-4">
                            <button type="submit" class="btn btn-outline-warning w-100">Replace</button>
                        </div>
                    </form>
                </div>

            </div>
        </section>
    }
}
