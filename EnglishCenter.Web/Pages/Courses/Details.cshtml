@page
@model EnglishCenter.Web.Pages.Courses.DetailsModel
@{
    ViewData["Title"] = "Chi tiết khóa học";
    ViewData["HideChrome"] = true;
}

<div class="courses-page">
    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="landing-container mt-3"><div class="alert alert-success mb-0">@successMessage</div></div>
    }
    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="landing-container mt-3"><div class="alert alert-danger mb-0">@errorMessage</div></div>
    }

    <header class="landing-header">
        <div class="landing-container landing-nav">
            <a class="landing-brand" href="/Index"><span class="landing-brand-icon">✦</span><span>English Center</span></a>

            <nav class="landing-menu">
                <a href="/Index">Về chúng tôi</a>
                <a class="active" href="/Courses/Index">Khóa học</a>
                <a href="#">Giáo viên</a>
                <a href="#">Liên hệ</a>
            </nav>

            @if (Model.IsStudentLoggedIn)
            {
                <div class="dropdown">
                    <button class="landing-register-btn dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        @Model.StudentDisplayName
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="/Student/Profile">Edit profile</a></li>
                        <li><a class="dropdown-item text-danger" href="/Account/Logout">Logout</a></li>
                    </ul>
                </div>
            }
            else
            {
                <a class="landing-register-btn" href="/Account/Register">Đăng ký ngay</a>
            }
        </div>
    </header>

    <section class="courses-hero">
        <div class="landing-container">
            <div class="courses-hero-box">
                <div>
                    <div class="landing-pill">📘 Chi tiết khóa học</div>
                    <h1>@Model.Course.Name</h1>
                    <p>@(string.IsNullOrWhiteSpace(Model.Course.Description) ? "Khóa học chuẩn quốc tế giúp học viên phát triển toàn diện kỹ năng tiếng Anh." : Model.Course.Description)</p>
                    <ul>
                        <li>Mã khóa học: @Model.Course.CourseCode</li>
                        <li>Tổng số buổi: @Model.Course.TotalSessions</li>
                        <li>
                            Độ tuổi:
                            @(Model.Course.AgeMin.HasValue || Model.Course.AgeMax.HasValue
                                ? $"{Model.Course.AgeMin?.ToString() ?? "?"} - {Model.Course.AgeMax?.ToString() ?? "?"} tuổi"
                                : "Mọi độ tuổi")
                        </li>
                        <li>Học phí tham khảo: @Model.Course.DefaultFee.ToString("N0")đ</li>
                    </ul>
                </div>
                <div>
                    @if (!Model.IsStudentLoggedIn)
                    {
                        <a class="btn-primary-landing" href="/Account/Register">Đăng ký ngay</a>
                    }
                    else if (Model.HasAnyEnrollment)
                    {
                        <a class="btn-primary-landing" href="/Student/Index">Vào học tập</a>
                    }
                    else
                    {
                        <form method="post" asp-page-handler="Register">
                            <input type="hidden" asp-for="Id" />
                            <button class="btn-primary-landing" type="submit">Đăng ký khóa học này</button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </section>

    <div class="landing-container mt-4">
        <a class="btn btn-outline-primary" href="/Courses/Index">← Quay lại danh sách khóa học</a>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
