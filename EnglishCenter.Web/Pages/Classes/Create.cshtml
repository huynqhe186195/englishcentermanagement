@page
@model EnglishCenter.Web.Pages.Classes.CreateModel
@{
    ViewData["Title"] = "Create Class";
}

<h2>Create Class</h2>

<form method="post">
    <div class="mb-3">
        <label class="form-label">Class Code</label>
        <input asp-for="Input.ClassCode" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Name</label>
        <input asp-for="Input.Name" class="form-control" />
    </div>
    <div class="row">
        <div class="col-md-4 mb-3">
            <label class="form-label">Start Date</label>
            <input asp-for="Input.StartDate" type="date" class="form-control" />
        </div>
        <div class="col-md-4 mb-3">
            <label class="form-label">End Date</label>
            <input asp-for="Input.EndDate" type="date" class="form-control" />
        </div>
        <div class="col-md-4 mb-3">
            <label class="form-label">Max Students</label>
            <input asp-for="Input.MaxStudents" type="number" class="form-control" />
        </div>
    </div>
    <div class="mb-3">
        <label class="form-label">Tuition Fee</label>
        <input asp-for="Input.TuitionFee" type="number" step="0.01" class="form-control" />
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label class="form-label">Course</label>
            <select asp-for="Input.CourseId" class="form-select" asp-items="Model.Courses">
                <option value="">-- Select course --</option>
            </select>
        </div>
        <div class="col-md-4 mb-3">
            <label class="form-label">Campus</label>
            <select asp-for="Input.CampusId" class="form-select" asp-items="Model.Campuses">
                <option value="">-- Select campus --</option>
            </select>
        </div>
        <div class="col-md-4 mb-3">
            <label class="form-label">Room</label>
            <select asp-for="Input.RoomId" class="form-select" asp-items="Model.Rooms">
                <option value="">-- Select room --</option>
            </select>
        </div>
    </div>

    <button class="btn btn-primary" type="submit">Create</button>
    <a asp-page="Index" class="btn btn-secondary">Cancel</a>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger mt-3">@Model.ErrorMessage</div>
    }
</form>