@page "{id:long}"
@model EnglishCenter.Web.Pages.Classes.DetailsModel
@{
    ViewData["Title"] = "Class Details";
}

<h2>Class Details</h2>

<div class="card">
    <div class="card-body">
        <h5 class="card-title">@Model.Item.Name (@Model.Item.ClassCode)</h5>
        <p class="card-text">Start: @Model.Item.StartDate &nbsp; End: @Model.Item.EndDate</p>
        <p class="card-text">Max Students: @Model.Item.MaxStudents</p>
        <p class="card-text">Tuition: @Model.Item.TuitionFee.ToString("C")</p>
        <p class="card-text">Status: @(Model.Item.Status==1?"Active":"Inactive")</p>

        <a asp-page="Edit" asp-route-id="@Model.Item.Id" class="btn btn-primary">Edit</a>
        <a asp-page="Index" class="btn btn-secondary">Back</a>
    </div>

<!-- Delete Exam Modal -->
<div class="modal fade" id="deleteExamModal" tabindex="-1" aria-labelledby="deleteExamModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="deleteExamModalLabel">Delete Exam</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p>Are you sure you want to delete exam <strong id="delExamTitle"></strong>?</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" id="confirmDeleteExam" class="btn btn-danger">Delete</button>
      </div>
    </div>
  </div>
</div>

<!-- Quick Add Exam Modal -->
<div class="modal fade" id="quickAddExamModal" tabindex="-1" aria-labelledby="quickAddExamModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="quickAddExamModalLabel">Quick Add Exam</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
            <label class="form-label">Title</label>
            <input id="quickExamTitle" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Exam Type</label>
            <select id="quickExamType" class="form-select">
                <option value="1">30 minutes</option>
                <option value="2">90 minutes</option>
            </select>
        </div>
        <div class="row g-2">
            <div class="col-md-6">
                <label class="form-label">Date</label>
                <input id="quickExamDate" type="date" class="form-control" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Time</label>
                <input id="quickExamTime" type="time" class="form-control" />
            </div>
        </div>
        <div class="mb-3 mt-3">
            <label class="form-label">Max Score</label>
            <input id="quickExamMaxScore" type="number" class="form-control" value="10" />
        </div>
        <div class="mb-3">
            <label class="form-label">Description (optional)</label>
            <textarea id="quickExamDescription" class="form-control" rows="2"></textarea>
        </div>
        <input type="hidden" id="quickExamClassId" value="@Model.Item.Id" />
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" id="quickAddExamSubmit" class="btn btn-primary">Add Exam</button>
      </div>
    </div>
  </div>
</div>

@section Scripts {
    <script>
        $(function() {
            var examIdToDelete = 0;
            $('#deleteExamModal').on('show.bs.modal', function (event) {
                var button = $(event.relatedTarget);
                examIdToDelete = button.data('examid');
                var title = button.data('examtitle');
                $('#delExamTitle').text(title);
            });

            $('#confirmDeleteExam').on('click', function() {
                if (!examIdToDelete) return;
                var url = '/api/exams/' + examIdToDelete;
                $.ajax({ url: url, type: 'DELETE' })
                    .done(function() {
                        showToast('Exam deleted', 'success');
                        // reload page
                        location.reload();
                    })
                    .fail(function() {
                        showToast('Delete failed', 'error');
                    });
            });
        });
    </script>
}
<script>
    $(function() {
        $('#quickAddExamSubmit').on('click', function() {
            var title = $('#quickExamTitle').val();
            var type = parseInt($('#quickExamType').val());
            var date = $('#quickExamDate').val();
            var time = $('#quickExamTime').val();
            var max = parseFloat($('#quickExamMaxScore').val() || '10');

            if (!date || !time) { showToast('Please select date and time', 'warning'); return; }

            var dt = new Date(date + 'T' + time + ':00');
            var iso = dt.toISOString();

            var classIdVal = parseInt($('#quickExamClassId').val() || '0', 10);
            var payload = {
                classId: classIdVal,
                title: title || 'Exam',
                examType: type,
                examDate: iso,
                maxScore: max,
                description: $('#quickExamDescription').val() || null
            };

            console.log('QuickAdd payload:', payload);

            // disable button and show progress
            var $btn = $('#quickAddExamSubmit');
            $btn.prop('disabled', true).text('Adding...');

            $.ajax({
                url: '/api/exams',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(payload)
            }).done(function() {
                showToast('Exam created', 'success');
                location.reload();
            }).fail(function(xhr) {
                var msg = 'Create failed';
                try {
                    var j = JSON.parse(xhr.responseText);
                    if (j && (j.message || j.Message)) msg = j.message || j.Message;
                } catch(e) {}
                showToast(msg, 'error');
            }).always(function() {
                $btn.prop('disabled', false).text('Add Exam');
            });
        });
    });
</script>
</div>

<div class="mt-4">
    <h4>Exams</h4>
    <div class="mb-2">
        <a class="btn btn-success" asp-page="/Exams/Schedule" asp-route-classId="@Model.Item.Id">Schedule Exam</a>
        <button class="btn btn-outline-success ms-2" data-bs-toggle="modal" data-bs-target="#quickAddExamModal">Quick Add Exam</button>
    </div>
    @if (Model.Exams?.Any() == true)
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ex in Model.Exams)
                {
                    <tr>
                        <td>@ex.Title</td>
                        <td>@ex.ExamDate.ToLocalTime()</td>
                        <td>@(ex.ExamType==1?"30 min":"90 min")</td>
                        <td>@(ex.Status==0?"Upcoming":ex.Status==1?"Ongoing":"Completed")</td>
                <td>
                            <a class="btn btn-sm btn-primary" asp-page="/Exams/Scores" asp-route-selectedExamId="@ex.Id">View Scores</a>
                            <a class="btn btn-sm btn-warning ms-1" asp-page="/Exams/Edit" asp-route-id="@ex.Id">Edit</a>
                            <button type="button" class="btn btn-sm btn-danger ms-1" data-bs-toggle="modal" data-bs-target="#deleteExamModal" data-examid="@ex.Id" data-examtitle="@ex.Title">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
    </div>
</div>