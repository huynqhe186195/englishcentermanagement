@page "{id:long}"
@model EnglishCenter.Web.Pages.Classes.DetailsModel
@{
    ViewData["Title"] = "Class Details";
}

<h2>Class Details</h2>

<div class="card">
    <div class="card-body">
        <h5 class="card-title">@Model.Item.Name (@Model.Item.ClassCode)</h5>
        <p class="card-text">Start: @Model.Item.StartDate &nbsp; End: @Model.Item.EndDate</p>
        <p class="card-text">Max Students: @Model.Item.MaxStudents</p>
        <p class="card-text">Tuition: @Model.Item.TuitionFee.ToString("C")</p>
        <p class="card-text">Status: @(Model.Item.Status==1?"Active":"Inactive")</p>

        <a asp-page="Edit" asp-route-id="@Model.Item.Id" class="btn btn-primary">Edit</a>
        <a asp-page="Index" class="btn btn-secondary">Back</a>
    </div>
</div>

<div class="mt-4">
    <h4>Exams</h4>
    <a class="btn btn-success mb-2" asp-page="/Exams/Schedule" asp-route-classId="@Model.Item.Id">Schedule Exam</a>
    @if (Model.Exams?.Any() == true)
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ex in Model.Exams)
                {
                    <tr>
                        <td>@ex.Title</td>
                        <td>@ex.ExamDate.ToLocalTime()</td>
                        <td>@(ex.ExamType==1?"30 min":"90 min")</td>
                        <td>@(ex.Status==0?"Upcoming":ex.Status==1?"Ongoing":"Completed")</td>
                        <td>
                            <a class="btn btn-sm btn-primary" asp-page="/Exams/Scores" asp-route-selectedExamId="@ex.Id">View Scores</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
    </div>
</div>