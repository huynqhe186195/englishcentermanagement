@page
@model EnglishCenter.Web.Pages.Account.CompleteStudentProfileModel
@{
    ViewData["Title"] = "Complete Student Profile";
    ViewData["HideChrome"] = true;
}

<div class="container py-4" style="max-width:900px;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Hoàn thiện hồ sơ học viên</h2>
        <a class="btn btn-outline-secondary" href="/Courses/Index">Về trang khóa học</a>
    </div>

    <div class="alert alert-info">
        Vui lòng điền đầy đủ thông tin hồ sơ trước khi đăng ký khóa học.
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Message))
    {
        <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger")">@Model.Message</div>
    }

    <form method="post" class="card card-body shadow-sm">
        <input type="hidden" asp-for="ReturnUrl" />

        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Họ tên</label>
                <input class="form-control" asp-for="ProfileForm.FullName" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Ngày sinh</label>
                <input class="form-control" type="date" asp-for="ProfileForm.DateOfBirth" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Giới tính</label>
                <select class="form-select" asp-for="ProfileForm.Gender">
                    <option value="">Chọn</option>
                    <option value="1">Nam</option>
                    <option value="2">Nữ</option>
                    <option value="3">Khác</option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label">Email</label>
                <input class="form-control" asp-for="ProfileForm.Email" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Số điện thoại</label>
                <input class="form-control" asp-for="ProfileForm.Phone" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Trường học</label>
                <input class="form-control" asp-for="ProfileForm.SchoolName" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Trình độ tiếng Anh</label>
                <input class="form-control" asp-for="ProfileForm.EnglishLevel" />
            </div>
            <div class="col-12">
                <label class="form-label">Ghi chú</label>
                <textarea class="form-control" rows="3" asp-for="ProfileForm.Note"></textarea>
            </div>
            <div class="col-md-3">
                <label class="form-label">Trạng thái</label>
                <select class="form-select" asp-for="ProfileForm.Status">
                    <option value="1">Active</option>
                    <option value="0">Inactive</option>
                </select>
            </div>
        </div>

        <div class="mt-3 d-flex gap-2">
            <button class="btn btn-primary" type="submit">Lưu hồ sơ</button>
            <a class="btn btn-outline-secondary" href="/Courses/Index">Hủy</a>
        </div>
    </form>
</div>
